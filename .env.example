# ============================================================
#  IBM Watsonx.ai — Nutrition Agent Configuration
#  Copy this file to .env and fill in your real credentials.
#  NEVER commit .env to version control.
# ============================================================

# --- IBM Cloud Credentials ---
IBM_API_KEY=your_ibm_cloud_api_key_here
IBM_WATSONX_URL=https://us-south.ml.cloud.ibm.com
IBM_PROJECT_ID=your_watsonx_project_id_here

# --- Model Settings ---
# Recommended: ibm/granite-13b-instruct-v2 or ibm/granite-3-8b-instruct
WATSONX_MODEL_ID=ibm/granite-3-8b-instruct

# --- Flask Settings ---
FLASK_SECRET_KEY=change_this_to_a_random_secret_key
FLASK_ENV=development
FLASK_DEBUG=True
FLASK_PORT=5000
